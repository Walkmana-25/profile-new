{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "profile-new",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "main": "./build/server/worker.js",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "./build/client",
    "html_handling": "auto-trailing-slash"
  }
}
